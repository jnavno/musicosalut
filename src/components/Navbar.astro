---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path ? "nav-link active" : "nav-link";

// Update this handle to your client's actual Instagram username
const instagramHandle = "moonseta";
---

<nav class="navbar navbar-expand-lg bg-body-tertiary" id="navigation">
  <div class="container-fluid" id="navigation-wrapper">
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav align-items-center">
        <li class="nav-item">
          <a
            class={isActive("/")}
            href="/"
            title="Anar a l'Inici"
            aria-label="Anar a la pàgina d'Inici"
          >
            Inici
          </a>
        </li>
        <li class="nav-item">
          <a
            class={isActive("/about")}
            href="/about"
            title="Saber-ne més sobre mi"
              aria-label="Anar a la pàgina Sobre mi"
          >
            Sobre mi
          </a>
        </li>
        <li class="nav-item">
          <a
            class={isActive("/help")}
            href="/help"
            title="Com et puc ajudar"
            aria-label="Anar a la pàgina d'ajuda terapèutica"
          >
            Com t'ajudo
          </a>
        </li>
        <li class="nav-item">
          <a
            class={isActive("/contact")}
            href="/contact"
            title="Contactar amb mi"
            aria-label="Anar a la pàgina de contacte"
          >
            Contacte
          </a>
        </li>

        {/* Instagram Icon */}
        <li class="nav-item ms-lg-3">
          <a 
            href={`https://www.instagram.com/${instagramHandle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link d-flex align-items-center"
            title="Segueix-me a Instagram"
            aria-label="Instagram"
          >
            <i class="bi bi-instagram fs-5"></i>
          </a>
        </li>
      </ul>
    </div>
  </div>
</nav>

<style>
  /* Optional: Adds the Instagram brand color on hover */
  .bi-instagram {
    transition: color 0.2s ease;
  }
  .nav-link:hover .bi-instagram {
    color: #E1306C;
  }
</style>