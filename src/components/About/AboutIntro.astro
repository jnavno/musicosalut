---
import { getEntry, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

const aboutLanding: CollectionEntry<"about"> | undefined = await getEntry("about", "about_me")
if (!aboutLanding) {
  throw new Error('Could not find about\'s "about_me" text')
}

const { Content } = await render(aboutLanding)

import { myInfo } from "src/data/myInfo"
const { myProf, fullProf, fullName } = myInfo
---

<section
  class="container-fluid justify-content-center row pt-5 px-sm-2 mb-1 px-4 px-xl-4 px-xl-5 over-hidden"
  aria-labelledby="about-intro-title"
>
  <div
    class="col-sm-10 col-md-7 col-lg-6 col-xl-6"
    data-aos="fade-up"
    data-aos-duration="1250"
  >
    <figure class="figure">
      <img
        src="/images/profile-2.webp"
        loading="lazy"
        class="figure-img img-fluid rounded"
        alt={`${fullName} writing notes`}
        title={fullName}
        aria-labelledby="about-intro-caption"
      >
      <figcaption class="figure-caption text-center fs-5" id="about-intro-caption">
        Certified {myProf}<br> Life Coach
      </figcaption>
    </figure>
  </div>
  <div
    class="intro-article col-sm-10 col-md-9 col-lg-8 col-xl-6"
    data-aos="fade-left"
    data-aos-duration="1250"
  >
    <h2 class="my-5 mt-2" id="about-intro-title">
      Sóc la {fullName}, {fullProf}.
    </h2>
    <Content />
  </div>
</section>
<hr id="about-intro-line" class="mb-4 mb-xl-5">