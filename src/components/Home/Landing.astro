---
import { getEntry, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

const homeLanding: CollectionEntry<"home"> | undefined = await getEntry("home", "landing")
if (!homeLanding) {
  throw new Error('Could not find home\'s "landing" text')
}

const { Content } = await render(homeLanding)

import { myInfo } from "../../data/myInfo"
const { fullName, myProf } = myInfo
---

<section
  class="container-fluid justify-content-center row px-sm-2 py-4 p-xl-4 py-xl-5 over-hidden"
  role="region"
  aria-labelledby="landing-title"
>
  <div class="col-sm-10 col-md-7 col-lg-6 col-xl-6">
    <figure class="figure" data-aos="fade-up" data-aos-duration="1500">
      <img
        src="/images/profile.webp"
        loading="lazy"
        class="figure-img img-fluid rounded"
        alt={`${fullName} somrient de manera propera`}
        title={fullName}
        aria-describedby="profile-caption"
      >
      <figcaption class="figure-caption text-center fs-5" id="profile-caption">
        {myProf} <br> i Acompanyament Emocional
      </figcaption>
    </figure>
  </div>
  <div
    class="intro-article col-sm-10 col-md-9 col-lg-8 col-xl-6"
    data-aos="fade-left"
    data-aos-duration="1500"
  >
    <p class="my-0">Benvingut / Benvinguda</p>
    <h2 class="my-5 mt-2" id="landing-title">
      Em dic {fullName}, i sóc {myProf}.
    </h2>
    <article>
      <Content />
    </article>
    <div class="landing-btns d-flex flex-column flex-sm-row justify-content-evenly pt-4">
      <a
        class="landing-btn btn contact-btn mb-3 mb-sm-0"
        href="/contact"
        title="Anar a la pàgina de contacte"
        aria-label="Demana una sessió de consulta"
      >
        Demana una sessió
      </a>
      <a
        class="landing-btn btn about-btn"
        href="/about"
        title="Saber-ne més sobre mi"
        aria-label={`Saber-ne més sobre ${fullName}`}
      >
        Més sobre mi
      </a>
    </div>
  </div>
</section>