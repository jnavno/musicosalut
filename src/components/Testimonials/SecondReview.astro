---
import { getEntry, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

const testimonialsLanding: CollectionEntry<"testimonials"> | undefined = await getEntry("testimonials", "second_review")
if (!testimonialsLanding) {
  throw new Error('Could not find testimonials\' "second_review" text')
}

const { Content } = await render(testimonialsLanding)

import { reviews } from "src/data/reviews"
const { secondReviewer } = reviews
---

<article
  class="container-fluid justify-content-center align-items-center row px-sm-2 py-4 p-xl-4 over-hidden"
  id="second-rev"
  aria-label={`${secondReviewer.fullName}'s testimonial`}
>
  <div class="col-sm-10 col-md-8 col-lg-6 col-xl-3">
    <figure class="figure" data-aos="fade-right" data-aos-duration="1250">
      <img
        src="/images/rev-img-2.webp"
        loading="lazy"
        class="figure-img img-fluid rounded"
        alt={`${secondReviewer.fullName} smiling`}
        title={secondReviewer.fullName}
        aria-labelledby="second-reviewer-caption"
        data-aos="flip-left"
        data-aos-duration="1250"
      >
      <figcaption class="text-center" id="second-reviewer-caption">
        <span class="rev-name">
          {secondReviewer.fullName}
        </span> <br>
        <span class="rev-job">
          {secondReviewer.profession}
        </span>
      </figcaption>
    </figure>
  </div>
  <div
    class="intro-article col-sm-10 col-md-8 col-lg-9 col-xl-8"
    data-aos="fade-left"
    data-aos-duration="1250"
  >
    <Content />
  </div>
</article>